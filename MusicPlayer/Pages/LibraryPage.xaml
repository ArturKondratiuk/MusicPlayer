<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="MusicPlayer.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:MusicPlayer.ViewModels"
    Title="Library">

    <VerticalStackLayout Padding="20">

        <Label
            FontSize="28"
            FontAttributes="Bold"
            Text="Music Library"/>

        <SearchBar
            Placeholder="Search songs..." />

        <Button
        x:Name="AddMusicButton"
        Margin="0,15,0,0"
        Clicked="AddMusicButton_Clicked"
        Text="Add Music" />

        <CollectionView
        Margin="0,20,0,0"
        ItemsSource="{Binding Songs}"
        SelectionMode="None">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Grid Padding="10"
                     ColumnDefinitions="*,Auto">

                        <VerticalStackLayout Grid.Column="0">

                            <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="{Binding Title}" />

                            <Label
                            FontSize="14"
                            Text="{Binding Artist}" />

                            <Label
                            FontSize="12"
                            Text="{Binding Album}" />

                        </VerticalStackLayout>

                        <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="5">

                            <Button
                            Text="Play"
                            Clicked="PlaySong_Clicked"
                            CommandParameter="{Binding}" />

                            <Button
                            Text="Delete"
                            Clicked="DeleteSong_Clicked"
                            CommandParameter="{Binding}" />

                        </VerticalStackLayout>
                    </Grid>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>