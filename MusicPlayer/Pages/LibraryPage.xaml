<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="MusicPlayer.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:MusicPlayer.ViewModels"
    Title="Library">

    <ContentPage.BindingContext>
        <viewmodels:LibraryViewModel/>
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20">

        <Label
            FontSize="28"
            FontAttributes="Bold"
            Text="Music Library"/>

        <SearchBar
            Placeholder="Search songs..." />

        <CollectionView
    Margin="0,20,0,0"
    ItemsSource="{Binding Songs}">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Grid Padding="10">

                        <VerticalStackLayout>

                            <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="{Binding Title}" />

                            <Label
                        FontSize="14"
                        Text="{Binding Artist}" />

                            <Label
                        FontSize="12"
                        Text="{Binding Album}" />

                        </VerticalStackLayout>

                    </Grid>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>