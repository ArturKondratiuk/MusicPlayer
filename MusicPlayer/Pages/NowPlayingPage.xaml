<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="MusicPlayer.Pages.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Now Playing">

    <VerticalStackLayout
        Padding="20"
        Spacing="20">

        <Image
            WidthRequest="250"
            HeightRequest="250"
            BackgroundColor="LightGray"
            Aspect="AspectFill" />

        <Label
            FontSize="28"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center"
            Text="{Binding Title}" />

        <Label
            FontSize="18"
            HorizontalTextAlignment="Center"
            Text="{Binding Artist}" />

        <Label
            FontSize="16"
            HorizontalTextAlignment="Center"
            Text="{Binding Album}" />

    </VerticalStackLayout>

</ContentPage>