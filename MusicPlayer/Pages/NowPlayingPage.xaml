<ContentPage
    x:Class="MusicPlayer.Pages.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Now Playing">

    <VerticalStackLayout
        Padding="20"
        Spacing="20">

        <Image
            HeightRequest="250"
            WidthRequest="250"
            HorizontalOptions="Center"/>

        <Label
            FontSize="24"
            HorizontalOptions="Center"
            Text="No song playing"/>

    </VerticalStackLayout>

</ContentPage>